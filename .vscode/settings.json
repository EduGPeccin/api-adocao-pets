{
  "editor.codeActionsOnSave": {
    "source.fixAll": "never", // desativa correções automáticas genéricas
    "source.fixAll.eslint": "always" //Sempre aplica correções automáticas do ESLint ao salvar
  },
  "editor.formatOnSave": true, // Ativa a formatação automática ao salvar o arquivo
  "editor.defaultFormatter": "esbenp.prettier-vscode"
}
